{
  "timeframe": {
    "minutes": 15,
    "bars_per_day": 96
  },
  "trading_params": {
    "min_gap_size": 5.0,
    "max_gap_age_bars": 96,
    "min_risk_reward": 2.5,
    "confidence_threshold": 0.65,
    "min_setup_age_bars": 1,
    "position_size": 1,
    "watchdog_touch_pts": 8.0
  },
  "position_sizing": {
    "base_contracts": 1,
    "max_contracts": 3,
    "scale_by_confidence": true,
    "confidence_tiers": [
      {"min_confidence": 0.65, "contracts": 1},
      {"min_confidence": 0.75, "contracts": 2},
      {"min_confidence": 0.85, "contracts": 3}
    ],
    "partial_exit": {
      "enabled": true,
      "scale1_r_multiple": 1.0,
      "scale1_pct": 0.5
    },
    "trailing_stop": {
      "enabled": true,
      "trail_points": 20
    }
  },
  "risk_management": {
    "stop_loss_min": 20,
    "stop_loss_default": 40,
    "stop_loss_max": 100,
    "stop_buffer": 10,
    "max_daily_trades": 5,
    "max_daily_loss": 100,
    "max_consecutive_losses": 3
  },
  "levels": {
    "psychological_intervals": [100],
    "confluence_tolerance": 10.0,
    "track_historical_strength": true
  },
  "memory": {
    "max_trades_stored": 1000,
    "query_similar_count": 20,
    "enable_adaptive_learning": true
  },
  "claude": {
    "model": "claude-sonnet-4-6",
    "temperature": 0.3,
    "max_tokens": 2000
  },
  "news_filters": {
    "enabled": true,
    "blackout_minutes_before": 30,
    "blackout_minutes_after": 30,
    "schedule_file": "data/news_schedule.json"
  },
  "session_rules": {
    "enabled": false,
    "allowed_sessions": ["ny_open", "london", "asian"],
    "ny_open": {
      "enabled": true,
      "start": "09:30",
      "end": "16:00",
      "description": "New York main session"
    },
    "london": {
      "enabled": true,
      "start": "03:00",
      "end": "12:00",
      "description": "London/European session"
    },
    "asian": {
      "enabled": true,
      "start": "18:00",
      "end": "02:00",
      "description": "Asian/overnight session (crosses midnight)"
    },
    "avoid_ny_open": true,
    "ny_open_blackout_minutes": 30,
    "avoid_lunch": true,
    "lunch_start": "12:00",
    "lunch_end": "13:00"
  },
  "logging": {
    "level": "INFO",
    "log_file": "trading_agent.log",
    "enable_console": true
  }
}
